{
  "langrev": "1",
  "version": "0.1.0",
  "build-dir": "build",
  "output": "build",
  "targets": {
    "zmm_lib": {
      "type": "dynamic-lib",
      "sources": [ "src/**" ]
    },
    "zmm_test": {
      "type": "executable",
      "sources": [ "test/main.c3" ],
      // 1. Tell the linker WHERE to look
      "linker-search-paths": [ "build" ],
      // 2. Tell the linker WHAT to link
      "linked-libraries": [ "zmm_lib" ]
    }
  }
}
